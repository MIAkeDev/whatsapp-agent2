# ====================================================
# Copia este archivo como .env y completa los valores
# En Railway ponlos como variables de entorno
# NUNCA subas el .env a GitHub
# ====================================================

# GROQ (gratis en console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# META WHATSAPP BUSINESS API
META_PHONE_NUMBER_ID=1234567890
META_WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxx
META_VERIFY_TOKEN=cualquier_palabra_secreta_que_tu_elijas

# BASE DE DATOS (Railway lo genera automático)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# REDIS (Railway lo genera automático)
REDIS_URL=redis://default:pass@host:6379

# MENSAJE DEFAULT (usa {nombre} para personalizar)
MENSAJE_DEFAULT=Hola {nombre}, le contactamos con una propuesta especial para usted. ¿Le gustaría conocer más detalles?

# CONFIGURACIÓN
RATE_LIMIT_POR_SEGUNDO=10
SCORE_ALERTA_MINIMO=60
